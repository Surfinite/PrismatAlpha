# PrismataAI Cloud Configuration
# Copy this file to cloud-config.env and fill in your values.
# cloud-config.env is gitignored and will not be committed.

# --- AWS ---
AWS_REGION=eu-north-1
AWS_AMI_WINDOWS=<your-windows-server-2022-ami-id>
AWS_AMI_DL_PYTORCH=<your-deep-learning-pytorch-ami-id>
AWS_AMI_LINUX=<your-amazon-linux-2023-ami-id>
AWS_SG_ID=<your-security-group-id>
AWS_KEY_NAME=<your-key-pair-name>
AWS_IAM_PROFILE=<your-iam-instance-profile-name>
CLOUD_BUCKET=<your-s3-bucket-name>

# --- GCP ---
GCP_PROJECT=<your-gcp-project-id>
GCP_ZONE=us-central1-a

# --- Azure ---
AZURE_RESOURCE_GROUP=<your-resource-group>
AZURE_LOCATION=northeurope
